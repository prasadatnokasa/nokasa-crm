{
  "name": "nokasa-crm",
  "main": "worker/index.js",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "build": {
    "command": "npm run build"
  },
  // Set this secret via: wrangler secret put CRM_PASSWORD
  // Then enter your chosen password when prompted
  "vars": {}
}
