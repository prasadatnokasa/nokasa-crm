{
  "name": "nokasa-crm",
  "main": "worker/index.js",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "build": {
    "command": "npm run build"
  },
  // After running: wrangler d1 create nokasa-crm-db
  // copy the database_id printed in terminal and paste it below
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nokasa-crm-db",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID"
    }
  ]
}
